# Render sets PORT; app config uses PORT over API_PORT for the listen port.
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OCR_PROVIDER=groq
GROQ_EXTRACTION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_STRUCTURING_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENAI_EXTRACTION_MODEL=gpt-4o-mini
OPENAI_STRUCTURING_MODEL=gpt-4o-mini
API_HOST=127.0.0.1
API_PORT=8001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
REQUEST_TIMEOUT_SECONDS=180
